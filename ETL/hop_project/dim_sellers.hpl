        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>480</xloc>
      <yloc>224</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
