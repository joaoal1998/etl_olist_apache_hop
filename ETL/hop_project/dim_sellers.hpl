    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <fields>
      <field>
        <name>seller_id</name>
        <length>32</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>seller_zip_code_prefix</name>
        <length>15</length>
        <type>Integer</type>
        <format>#</format>
        <trim_type>none</trim_type>
        <precision>0</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
      <field>
