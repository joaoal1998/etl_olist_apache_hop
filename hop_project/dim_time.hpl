  <transform>
    <type>ScriptValueMod</type>
    <name>JavaScript</name>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var str = datum_date + "";
var datum_date_out = null;
var time_day = null;
var time_month = null;
var time_year = null;
var time_weekday = null;
var time_quarter = null;

if (str.length == 19 || str.length == 16) {
  try {
    var d = str2date(str, "yyyy-MM-dd HH:mm:ss");
    datum_date_out = d;
    time_day = d.getDate();
    time_month = d.getMonth() + 1;
    time_year = d.getFullYear();
    var days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
    time_weekday = days[d.getDay()];
    var q = Math.ceil(time_month / 3);
    time_quarter = "Q" + q;
  } catch(e) {}
}</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
